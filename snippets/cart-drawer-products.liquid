{%- doc -%}
  Renders the cart line items in the drawer using the custom design.
  Preserves all refs, events, and form structure required by component-cart-items.js.
{%- enddoc -%}

<script
  src="{{ 'component-cart-items.js' | asset_url }}"
  type="module"
  fetchpriority="low"
></script>
<script
  src="{{ 'component-cart-quantity-selector.js' | asset_url }}"
  type="module"
  fetchpriority="low"
></script>

<div class="cart-drawer-items">
  {% if cart.empty? %}
    {%- if shop.customer_accounts_enabled and customer == null -%}
      <p class="cart-drawer-items__empty-text">
        {{ 'actions.log_in_html' | t: link: routes.account_login_url }}
      </p>
    {%- endif -%}

    <a
      class="cart-drawer-items__empty-button"
      href="{{ settings.empty_cart_button_link | default: routes.all_products_collection_url }}"
    >
      {{ 'actions.continue_shopping' | t }}
    </a>
  {%- else -%}
    <span class="visually-hidden" ref="cartItemCount" aria-hidden="true">
      {{- cart.item_count -}}
    </span>

    <form
      action="{{ routes.cart_url }}"
      class="cart-form"
      id="cart-form"
      method="post"
    >
      <ul class="cart-drawer-items__list" role="list">
        {% for item in cart.items %}
          {%- liquid
            assign can_update_quantity = item.instructions.can_update_quantity | default: true, allow_false: true
            assign can_remove = item.instructions.can_remove | default: true, allow_false: true
            assign line_number = item.index | plus: 1
          -%}
          <li
            class="cart-drawer-items__item{% if item.parent_relationship.parent != null %} cart-drawer-items__item--nested{% endif %}"
            ref="cartItemRows[]"
            data-key="{{ item.key }}"
            data-parent-key="{{ item.parent_relationship.parent.key }}"
          >
            <div class="cart-drawer-items__main">
              <a href="{{ item.url }}" class="cart-drawer-items__media">
                {%- if item.image -%}
                  {{ item.image | image_url: width: 240 | image_tag:
                    loading: 'lazy',
                    width: 60,
                    height: 60,
                    class: 'cart-drawer-items__image'
                  }}
                {%- endif -%}
              </a>

              <div class="cart-drawer-items__info">
                <a href="{{ item.url }}" class="cart-drawer-items__title">
                  {{- item.product.title -}}
                </a>

                {%- if item.product.has_only_default_variant == false and item.item_components.size == 0 -%}
                  {%- for option in item.options_with_values -%}
                    <p class="cart-drawer-items__variant">
                      <span>{{ option.name }}:</span>
                      <span>{{ option.value }}</span>
                    </p>
                  {%- endfor -%}
                {%- endif -%}

                {%- liquid
                  assign has_visible_properties = false
                  for property in item.properties
                    assign property_first_char = property.first | slice: 0
                    if property.last != blank and property_first_char != '_'
                      assign has_visible_properties = true
                      break
                    endif
                  endfor
                -%}
                {%- if has_visible_properties -%}
                  {%- for property in item.properties -%}
                    {%- assign property_first_char = property.first | slice: 0 -%}
                    {%- if property.last != blank and property_first_char != '_' -%}
                      <p class="cart-drawer-items__variant">
                        <span>{{ property.first }}:</span>
                        <span>
                          {%- if property.last contains '/uploads/' -%}
                            <a href="{{ property.last }}">{{ property.last | split: '/' | last }}</a>
                          {%- else -%}
                            {{ property.last }}
                          {%- endif -%}
                        </span>
                      </p>
                    {%- endif -%}
                  {%- endfor -%}
                {%- endif -%}

                {%- liquid
                  # Use line totals (qty * unit) so prices update with quantity changes.
                  assign line_price = item.final_line_price
                  assign original_line_price = item.original_line_price

                  # If variant has a higher compare-at MSRP, use it as the strikethrough line price.
                  assign compare_line_price = 0
                  if item.variant.compare_at_price != null and item.variant.compare_at_price > item.variant.price
                    assign compare_line_price = item.variant.compare_at_price | times: item.quantity
                  endif
                -%}
                <div class="cart-drawer-items__price">
                  {%- if compare_line_price > line_price -%}
                    <span class="visually-hidden">{{ 'content.price_sale' | t }}</span>
                    <s>{{ compare_line_price | money }}</s>
                    <text-component value="{{ line_price | money | strip_html }}">{{ line_price | money }}</text-component>
                  {%- elsif line_price < original_line_price -%}
                    <span class="visually-hidden">{{ 'content.price_sale' | t }}</span>
                    <s>{{ original_line_price | money }}</s>
                    <text-component value="{{ line_price | money | strip_html }}">{{ line_price | money }}</text-component>
                  {%- else -%}
                    <text-component value="{{ line_price | money | strip_html }}">{{ line_price | money }}</text-component>
                  {%- endif -%}
                </div>

                {%- if item.selling_plan_allocation -%}
                  <p class="cart-drawer-items__subscription">
                    {{ item.selling_plan_allocation.selling_plan.name }}
                  </p>
                {%- endif -%}

                {%- if item.line_level_discount_allocations.size > 0 -%}
                  <ul class="cart-drawer-items__discounts" role="list">
                    {%- for discount in item.line_level_discount_allocations -%}
                      <li>{{ discount.discount_application.title | escape }}</li>
                    {%- endfor -%}
                  </ul>
                {%- endif -%}
              </div>

              <div class="cart-drawer-items__controls">
                <button
                  type="button"
                  class="cart-drawer-items__remove"
                  aria-label="{{ 'accessibility.remove_item' | t: title: item.title | escape }}"
                  on:click="/onLineItemRemove/{{ line_number }}"
                  {% if can_remove == false %}hidden{% endif %}
                >
                  {{- 'icon-delete.svg' | inline_asset_content -}}
                </button>

                <div class="cart-drawer-items__quantity">
                  {% render 'quantity-selector',
                    product: item.product,
                    variant: item.variant,
                    in_cart_quantity: item.quantity,
                    line_index: item.index,
                    class: 'cart-drawer-items__qty-selector',
                    can_update_quantity: can_update_quantity,
                    min: 0
                  %}
                </div>
              </div>
            </div>

            <div
              class="cart-drawer-items__error hidden"
              ref="cartItemErrorContainer-{{ line_number }}"
              role="alert"
            >
              <span class="svg-wrapper">{{- 'icon-error.svg' | inline_asset_content -}}</span>
              <small ref="cartItemError-{{ line_number }}"></small>
            </div>
          </li>
        {% endfor %}
      </ul>
    </form>
  {%- endif -%}
</div>

{% stylesheet %}
  .cart-drawer-items {
    display: flex;
    flex-direction: column;
    gap: 16px;
    width: 100%;
    padding: 0 15px;
  }

  .cart-drawer-items.cart-items-disabled {
    pointer-events: none;
  }

  .cart-drawer-items__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 16px;
    width: 100%;
  }

  .cart-drawer-items__item {
    border-bottom: 1px solid var(--color-border, currentColor);
    padding-bottom: 16px;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .cart-drawer-items__item:last-child {
    border-bottom: none;
    padding-bottom: 0;
  }

  .cart-drawer-items__item.removing {
    overflow: hidden;
    animation: removeRow calc(var(--animation-speed) * 2) var(--animation-easing) forwards;
    animation-delay: var(--animation-speed);
  }

  @keyframes removeRow {
    0% {
      height: var(--row-height);
    }
    100% {
      opacity: 0;
      height: 0;
      padding-bottom: 0;
      margin-bottom: 0;
      border-color: transparent;
    }
  }

  .cart-drawer-items__main {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 16px;
    width: 100%;
  }

  .cart-drawer-items__media {
    flex-shrink: 0;
    width: 60px;
    height: 60px;
    background-color: var(--color-background, transparent);
    overflow: hidden;
    display: block;
  }

  .cart-drawer-items__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .cart-drawer-items__info {
    flex: 1 1 0;
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 6px;
    color: var(--color-foreground, inherit);
  }

  .cart-drawer-items__title {
    font-family: 'Inter', sans-serif;
    font-weight: 700;
    font-size: 16px;
    line-height: 1.1;
    color: inherit;
    text-decoration: none;
  }

  .cart-drawer-items__variant {
    font-family: 'Inter', sans-serif;
    font-weight: 400;
    font-size: 14px;
    line-height: 1.1;
    margin: 0;
    display: flex;
    gap: 4px;
    align-items: center;
  }

  .cart-drawer-items__variant a {
    color: inherit;
  }

  .cart-drawer-items__price {
    font-family: 'Inter', sans-serif;
    font-weight: 400;
    font-size: 16px;
    line-height: 1.1;
    display: flex;
    gap: 8px;
    align-items: center;
  }

  .cart-drawer-items__price s {
    text-decoration: line-through;
  }

  .cart-drawer-items__subscription {
    font-family: 'Inter', sans-serif;
    font-weight: 400;
    font-size: 14px;
    line-height: 1.1;
    color: var(--color-link, currentColor);
    margin: 0;
  }

  .cart-drawer-items__discounts {
    list-style: none;
    margin: 0;
    padding: 0;
    font-size: 13px;
    color: var(--color-link, currentColor);
  }

  .cart-drawer-items__controls {
    flex-shrink: 0;
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    justify-content: space-between;
    align-self: stretch;
    gap: 12px;
  }

  .cart-drawer-items__remove {
    width: 20px;
    height: 20px;
    background: transparent;
    border: none;
    padding: 0;
    cursor: pointer;
    color: var(--color-foreground, inherit);
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }

  .cart-drawer-items__remove svg {
    width: 100%;
    height: 100%;
    display: block;
  }

  .cart-drawer-items__remove .remove-icon-bottom,
  .cart-drawer-items__remove .remove-icon-top {
    transition: transform var(--animation-speed) var(--animation-easing);
  }

  .cart-drawer-items__remove:hover .remove-icon-top {
    transform: translate(calc(-1 * var(--icon-stroke-width)), var(--icon-stroke-width)) rotate(-15deg);
  }

  .cart-drawer-items__remove:is(:hover, :active) .remove-icon-bottom {
    transform: translateY(var(--icon-stroke-width));
  }

  .cart-drawer-items__quantity .quantity-selector-wrapper {
    width: auto;
    flex-wrap: nowrap;
    gap: 0;
  }

  .cart-drawer-items__qty-selector {
    --qty-border-color: var(--color-foreground, inherit);
    --quantity-selector-width: 111px;

    flex: none;
    box-sizing: border-box;
    width: 111px;
    min-width: 111px;
    height: auto;
    background-color: var(--color-background-subdued, transparent);
    border: 1.5px solid var(--qty-border-color);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 16px;
    padding: 6px;
    font-family: 'Inter', sans-serif;
  }

  .cart-drawer-items__qty-selector input {
    background: transparent;
    border: none;
    color: var(--color-foreground, inherit);
    font-weight: 700;
    font-size: 16px;
    text-align: center;
    width: auto;
    max-width: 24px;
    padding: 0;
    height: auto;
    -moz-appearance: textfield;
  }

  .cart-drawer-items__qty-selector input::-webkit-outer-spin-button,
  .cart-drawer-items__qty-selector input::-webkit-inner-spin-button {
    -webkit-appearance: none;
    margin: 0;
  }

  .cart-drawer-items__qty-selector :is(.quantity-minus, .quantity-plus, button) {
    width: 24px;
    height: 24px;
    min-width: 0;
    min-height: 0;
    flex-shrink: 0;
    background: transparent;
    border: none;
    color: var(--color-foreground, inherit);
    padding: 0;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
  }

  .cart-drawer-items__qty-selector button svg,
  .cart-drawer-items__qty-selector button .svg-wrapper {
    width: 100%;
    height: 100%;
  }

  .cart-drawer-items__qty-selector button:disabled {
    opacity: 0.4;
    cursor: not-allowed;
  }

  .cart-drawer-items__error {
    display: flex;
    align-items: flex-start;
    gap: 6px;
    font-family: 'Inter', sans-serif;
    font-size: 13px;
    color: var(--color-error, currentColor);
    padding: 4px 0;
  }

  .cart-drawer-items__error.hidden {
    display: none;
  }

  .cart-drawer-items__error .svg-wrapper {
    width: var(--icon-size-xs, 14px);
    height: var(--icon-size-xs, 14px);
    flex-shrink: 0;
    margin-top: 2px;
  }

  .cart-drawer-items__empty-button {
    background-color: var(--color-foreground, inherit);
    color: var(--color-border, currentColor);
    font-family: 'Inter', sans-serif;
    font-weight: 700;
    font-size: 16px;
    text-transform: uppercase;
    text-decoration: none;
    padding: 16px 24px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    margin-top: 16px;
  }

  .cart-drawer-items__empty-text {
    text-align: center;
    margin: 0;
    font-family: 'Inter', sans-serif;
    font-size: 14px;
  }
{% endstylesheet %}
