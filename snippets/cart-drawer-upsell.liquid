{%- doc -%}
  Renders a "You might also like" upsell card in the cart drawer.
  Uses Shopify's /recommendations/products endpoint based on the first cart item.
  Refreshes automatically when the cart changes (via section morph + CartUpdateEvent).
{%- enddoc -%}

{% if settings.cart_upsell_enabled and cart.items.first %}
  {%- assign first_product_id = cart.items.first.product.id -%}

  <script
    src="{{ 'cart-drawer-upsell.js' | asset_url }}"
    type="module"
    fetchpriority="low"
  ></script>

  <cart-drawer-upsell
    class="cart-drawer-upsell"
    data-product-id="{{ first_product_id }}"
    data-section-id="cart-drawer-upsell"
  >
    <div class="cart-drawer-upsell__placeholder" aria-hidden="true"></div>
  </cart-drawer-upsell>
{% endif %}

{% stylesheet %}
  .cart-drawer-upsell {
    display: block;
    width: 100%;
  }

  .cart-drawer-upsell__placeholder {
    min-height: 92px;
  }

  .cart-drawer-upsell__card {
    background-color: var(--color-background-subdued, transparent);
    border: 1px solid var(--color-border, currentColor);
    padding: 16px 12px;
    display: flex;
    flex-direction: column;
    gap: 12px;
    margin: 1rem;
  }

  .cart-drawer-upsell__heading {
    display: flex;
  }

  .cart-drawer-upsell__title {
    font-family: var(--font-heading--family, inherit);
    font-weight: 600;
    font-size: 18px;
    line-height: 1;
    color: var(--color-foreground, inherit);
    text-transform: uppercase;
    margin: 0;
  }

  .cart-drawer-upsell__row {
    display: flex;
    align-items: center;
    gap: 12px;
    width: 100%;
  }

  .cart-drawer-upsell__media {
    flex-shrink: 0;
    width: 60px;
    height: 60px;
    background-color: var(--color-background, transparent);
    overflow: hidden;
    display: block;
  }

  .cart-drawer-upsell__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .cart-drawer-upsell__info {
    flex: 1 1 0;
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 6px;
    color: var(--color-foreground, inherit);
  }

  .cart-drawer-upsell__name {
    font-family: var(--font-heading--family, inherit);
    font-weight: 600;
    font-size: 16px;
    line-height: 1;
    text-transform: uppercase;
    color: inherit;
    text-decoration: none;
  }

  .cart-drawer-upsell__variant {
    font-family: 'Inter', sans-serif;
    font-size: 14px;
    line-height: 1;
    margin: 0;
  }

  .cart-drawer-upsell__price {
    font-family: 'Inter', sans-serif;
    font-size: 16px;
    line-height: 1;
    margin: 0;
    display: flex;
    gap: 8px;
    align-items: center;
  }

  .cart-drawer-upsell__price s {
    text-decoration: line-through;
  }

  .cart-drawer-upsell__form {
    flex-shrink: 0;
    margin: 0;
  }

  .cart-drawer-upsell__button {
    background-color: var(--color-foreground, inherit);
    color: var(--color-border, currentColor);
    font-family: 'Inter', sans-serif;
    font-weight: 700;
    font-size: 16px;
    line-height: 1;
    text-transform: uppercase;
    padding: 16px 24px;
    border: none;
    cursor: pointer;
    transition: opacity 0.2s ease;
  }

  .cart-drawer-upsell__button:hover:not(:disabled) {
    opacity: 0.9;
  }

  .cart-drawer-upsell__button:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }
{% endstylesheet %}
