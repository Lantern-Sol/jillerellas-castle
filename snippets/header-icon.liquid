{%- doc -%}
  Renders a header action icon.

  Uses a merchant-uploaded image when one is set on the matching header setting,
  otherwise falls back to the brand default SVG (which matches the Figma design).
  The default SVGs use `currentColor`, so they inherit the header text color;
  uploaded images render as `<img>` sized to the icon box.

  @param {image} [icon] - Optional merchant-uploaded icon (from an image_picker setting).
  @param {string} name - Default asset base name, e.g. 'search' -> assets/icon-search.svg.
    One of: search, account, cart, menu.

  @example
  {% render 'header-icon', icon: section.settings.header_icon_search, name: 'search' %}
{%- enddoc -%}

{%- liquid
  assign default_asset = 'icon-' | append: name | append: '.svg'
-%}

{%- if icon != blank -%}
  {{
    icon
    | image_url: width: 88
    | image_tag:
      loading: 'lazy',
      widths: '22, 44, 88',
      class: 'header-icon-custom',
      alt: ''
  }}
{%- else -%}
  {{- default_asset | inline_asset_content -}}
{%- endif -%}

{% stylesheet %}
  .header-icon-custom {
    display: block;
    width: var(--icon-size-md, 1.375rem);
    height: var(--icon-size-md, 1.375rem);
    object-fit: contain;
  }

  /* Match the per-context sizing/padding the default SVGs receive, so an
     uploaded icon is a true drop-in replacement rather than rendering larger. */

  /* Account button insets its default svg by 2px (border-box) -> ~18px glyph. */
  .header-actions__action.account-button .header-icon-custom {
    padding: 2px;
  }

  /* The mobile drawer hamburger toggle sizes its default svg to --icon-size-sm. */
  .header__icon--summary .header-drawer-icon .header-icon-custom {
    width: var(--icon-size-sm, 1.25rem);
    height: var(--icon-size-sm, 1.25rem);
  }
{% endstylesheet %}
