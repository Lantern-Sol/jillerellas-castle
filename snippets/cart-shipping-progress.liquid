{%- doc -%}
  Free shipping progress bar shown at the top of the cart drawer.
  Reads `settings.cart_free_shipping_threshold` (in store currency major units).
{%- enddoc -%}

{% liquid
  assign threshold_input = settings.cart_free_shipping_threshold | default: '50'
  assign threshold_cents = threshold_input | times: 100.0 | round

  if threshold_cents <= 0
    assign threshold_cents = 5000
  endif

  assign current = cart.total_price
  assign remaining_cents = threshold_cents | minus: current
  if remaining_cents < 0
    assign remaining_cents = 0
  endif

  assign progress_percent = current | times: 1.0 | divided_by: threshold_cents | times: 100 | round
  if progress_percent > 100
    assign progress_percent = 100
  endif
  if progress_percent < 0
    assign progress_percent = 0
  endif

  assign goal_met = false
  if cart.item_count > 0 and remaining_cents == 0
    assign goal_met = true
  endif
%}

<div class="cart-shipping-progress">
  <p class="cart-shipping-progress__text">
    {%- if goal_met -%}
      <span>You&rsquo;ve unlocked </span><strong>free shipping!</strong>
    {%- else -%}
      <span>Add </span><strong>{{ remaining_cents | money }}</strong><span> to your order to </span><strong>unlock free shipping!</strong>
    {%- endif -%}
  </p>

  <div
    class="cart-shipping-progress__bar"
    role="progressbar"
    aria-valuemin="0"
    aria-valuemax="100"
    aria-valuenow="{{ progress_percent }}"
    style="--progress: {{ progress_percent }}%;"
  >
    <span class="cart-shipping-progress__track"></span>
    <span class="cart-shipping-progress__fill"></span>

    <span class="cart-shipping-progress__icon cart-shipping-progress__icon--truck" aria-hidden="true">
      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="10" viewBox="0 0 14 10" fill="none">
        <path d="M1 1.5h7v5.25H1zM8 3h2.5l2 2v1.75H8z" stroke="currentColor" stroke-width="0.8" stroke-linejoin="round"/>
        <circle cx="3.25" cy="7.75" r="1" fill="currentColor"/>
        <circle cx="10.25" cy="7.75" r="1" fill="currentColor"/>
      </svg>
    </span>

    <span class="cart-shipping-progress__icon cart-shipping-progress__icon--gift" aria-hidden="true">
      <svg xmlns="http://www.w3.org/2000/svg" width="13" height="10" viewBox="0 0 13 10" fill="none">
        <path d="M1 4h11v5.5H1zM6.5 4v5.5M1 2h11v2H1zM6.5 2c-1-1.4 0-2 .8-1.4.6.5.4 1.4-.8 1.4Zm0 0c1-1.4 0-2-.8-1.4-.6.5-.4 1.4.8 1.4Z" stroke="currentColor" stroke-width="0.8" stroke-linejoin="round"/>
      </svg>
    </span>
  </div>
</div>

{% stylesheet %}
  .cart-shipping-progress {
    --progress-track-color: var(--color-border, currentColor);
    --progress-fill-color: var(--color-link, currentColor);
    --progress-icon-bg: var(--color-border, currentColor);
    --progress-icon-color: var(--color-foreground, inherit);

    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 12px;
    width: 100%;
    padding: 0 15px;
  }

  .cart-shipping-progress__text {
    font-family: 'Inter', sans-serif;
    font-size: 14px;
    line-height: 1.4;
    color: var(--color-foreground, inherit);
    text-align: center;
    margin: 0;
  }

  .cart-shipping-progress__text strong {
    font-weight: 700;
  }

  .cart-shipping-progress__bar {
    position: relative;
    width: 100%;
    height: 6px;
  }

  .cart-shipping-progress__track {
    position: absolute;
    inset: 0;
    background-color: var(--progress-track-color);
    border-radius: 0 12px 12px 0;
    display: block;
  }

  .cart-shipping-progress__fill {
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: var(--progress, 0%);
    background-color: var(--progress-fill-color);
    transition: width 0.4s ease;
    display: block;
  }

  .cart-shipping-progress__icon {
    position: absolute;
    top: 50%;
    width: 22px;
    height: 22px;
    background-color: var(--progress-icon-bg);
    border: 1px solid var(--progress-icon-bg);
    border-radius: 50%;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: var(--progress-icon-color);
    transform: translate(-50%, -50%);
    pointer-events: none;
  }

  .cart-shipping-progress__icon--truck {
    left: var(--progress, 0%);
    transition: left 0.4s ease;
  }

  .cart-shipping-progress__icon--gift {
    left: 100%;
  }

  .cart-shipping-progress__icon svg {
    display: block;
  }
{% endstylesheet %}
