{%- doc -%}
  Floating bundle bar.

  Shown inside a Build-a-box section. Hidden by JS when the bundle is empty.
  Slots are filled from the bundle cookie by `<bundle-bar>` (build-a-box.js).

  @param {object} section - The parent section (Build a box) for settings.
{%- enddoc -%}

{%- liquid
  assign max_items = section.settings.max_items | default: 4
  assign bar_title = section.settings.bar_title | default: 'YOUR BUNDLE'
  assign bar_cta = section.settings.bar_cta | default: 'ADD BUNDLE TO CART'
-%}

<bundle-bar
  class="bundle-bar"
  data-section-id="{{ section.id }}"
  data-max-items="{{ max_items }}"
  data-min-items="{{ section.settings.min_items | default: 4 }}"
  hidden
>
  <div class="bundle-bar__inner">
    <div class="bundle-bar__heading">
      <span class="bundle-bar__title">
        {{ bar_title }}
        <span class="bundle-bar__count">
          (<span ref="filledCount">0</span>/{{ max_items }})
        </span>
      </span>
    </div>

    <div class="bundle-bar__slots" ref="slots">
      {%- for i in (1..max_items) -%}
        <div class="bundle-bar__slot bundle-bar__slot--empty" data-slot-index="{{ forloop.index0 }}">
          <div class="bundle-bar__slot-placeholder">
            <span class="bundle-bar__plus" aria-hidden="true">+</span>
          </div>
        </div>
      {%- endfor -%}
    </div>

    <button
      type="button"
      class="bundle-bar__cta button"
      ref="cta"
      on:click="bundle-bar/handleSubmit"
      disabled
    >
      {{ bar_cta }}
    </button>
  </div>
</bundle-bar>

{% stylesheet %}
  .bundle-bar {
    position: fixed;
    left: 0;
    right: 0;
    bottom: 0;
    z-index: var(--layer-overlay, 80);
    box-shadow: 0 -2px 16px rgb(0 0 0 / 0.08);
    border-top: 1px solid rgb(var(--color-foreground-rgb) / 0.08);
    background-color: var(--color-background);
    color: var(--color-foreground);
    transform: translateY(0);
    transition: transform 0.25s var(--animation-easing, ease-out);
  }

  .bundle-bar[hidden] {
    display: none;
  }

  .bundle-bar__inner {
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: clamp(0.75rem, 2vw, 1.5rem);
    padding-inline: clamp(1rem, 3vw, 2rem);
    padding-block: 1rem;
    max-width: 1440px;
    margin-inline: auto;
  }

  .bundle-bar__heading {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .bundle-bar__title {
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    font-size: 0.875rem;
    white-space: nowrap;
  }

  .bundle-bar__count {
    opacity: 0.7;
    font-weight: 500;
  }

  .bundle-bar__slots {
    display: grid;
    grid-auto-flow: column;
    grid-auto-columns: minmax(0, 1fr);
    gap: 0.75rem;
    min-width: 0;
  }

  .bundle-bar__slot {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    padding: 0.5rem 0.625rem;
    border: 1px dashed rgb(var(--color-foreground-rgb) / 0.35);
    border-radius: var(--style-border-radius-popover, 4px);
    min-height: 4rem;
    background-color: rgb(var(--color-foreground-rgb) / 0.02);
    position: relative;
    overflow: hidden;
  }

  .bundle-bar__slot--filled {
    border-style: solid;
    border-color: rgb(var(--color-foreground-rgb) / 0.12);
    background-color: var(--color-background);
  }

  .bundle-bar__slot-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .bundle-bar__plus {
    font-size: 1.5rem;
    line-height: 1;
    opacity: 0.4;
  }

  .bundle-bar__slot-image {
    width: 3rem;
    height: 3rem;
    flex: 0 0 auto;
    object-fit: cover;
    background-color: rgb(var(--color-foreground-rgb) / 0.05);
    border-radius: 2px;
  }

  .bundle-bar__slot-info {
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
    min-width: 0;
    flex: 1 1 auto;
    font-size: 0.75rem;
    line-height: 1.25;
  }

  .bundle-bar__slot-title {
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .bundle-bar__slot-meta {
    opacity: 0.75;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .bundle-bar__slot-remove {
    position: absolute;
    top: 2px;
    right: 2px;
    width: 1.25rem;
    height: 1.25rem;
    border-radius: 50%;
    border: 0;
    background: rgb(var(--color-foreground-rgb) / 0.08);
    color: var(--color-foreground);
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: 0.875rem;
    line-height: 1;
    padding: 0;
  }

  .bundle-bar__slot-remove:hover {
    background: rgb(var(--color-foreground-rgb) / 0.16);
  }

  .bundle-bar__cta {
    white-space: nowrap;
    padding-inline: clamp(1rem, 3vw, 2.5rem);
  }

  .bundle-bar__cta[disabled] {
    opacity: 0.5;
    cursor: not-allowed;
  }

  @media screen and (max-width: 749px) {
    .bundle-bar__inner {
      grid-template-columns: 1fr;
      gap: 0.75rem;
      padding-block: 0.75rem;
    }

    .bundle-bar__heading {
      flex-direction: row;
      align-items: center;
      justify-content: space-between;
    }

    .bundle-bar__slots {
      overflow-x: auto;
      scrollbar-width: none;
      grid-auto-columns: 9.5rem;
    }

    .bundle-bar__slots::-webkit-scrollbar {
      display: none;
    }

    .bundle-bar__cta {
      width: 100%;
    }
  }
{% endstylesheet %}
