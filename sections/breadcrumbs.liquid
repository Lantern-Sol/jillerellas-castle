{%- liquid
  assign separator = section.settings.separator
  assign home_label = section.settings.home_label
  if home_label == blank
    assign home_label = 'Home'
  endif
-%}

{% render 'contrast-override', background_color: section.settings.background_color, section_id: section.id %}
<div class="section-background{% if section.settings.background_color != blank %} color-custom-{{ section.id }}{% endif %}"></div>
<div
  class="section section--{{ section.settings.section_width }} spacing-style breadcrumbs{% if section.settings.background_color != blank %} color-custom-{{ section.id }}{% endif %}"
  style="
    {%- render 'spacing-style', settings: section.settings -%}
    --breadcrumbs-separator: '{{ separator }}';
  "
>
  <nav
    class="breadcrumbs__nav"
    aria-label="Breadcrumb"
  >
    <ol class="breadcrumbs__list">
      <li class="breadcrumbs__item">
        <a class="breadcrumbs__link" href="{{ routes.root_url }}">{{ home_label }}</a>
      </li>

      {%- case template.name -%}
        {%- when 'collection' -%}
          {%- if section.settings.show_collection_parent -%}
            {%- liquid
              assign parent_label = section.settings.collection_parent_label
              if parent_label == blank
                assign parent_label = 'Collection'
              endif
            -%}
            <li class="breadcrumbs__item">
              <a class="breadcrumbs__link" href="{{ routes.collections_url }}">{{ parent_label }}</a>
            </li>
          {%- endif -%}
          <li class="breadcrumbs__item" aria-current="page">
            <span class="breadcrumbs__current">{{ collection.title }}</span>
          </li>

        {%- when 'product' -%}
          {%- liquid
            assign category_label = ''
            assign category_url = ''
            assign source = section.settings.product_category_source

            if source == 'category'
              assign category_label = product.category.name
            elsif source == 'type'
              assign category_label = product.type
            elsif source == 'collection'
              assign parent_collection = collection
              if parent_collection.handle == blank
                assign parent_collection = product.collections.first
              endif
              if parent_collection.handle != blank
                assign category_label = parent_collection.title
                assign category_url = parent_collection.url
              endif
            else
              if product.category.name != blank
                assign category_label = product.category.name
              elsif product.type != blank
                assign category_label = product.type
              else
                assign parent_collection = collection
                if parent_collection.handle == blank
                  assign parent_collection = product.collections.first
                endif
                if parent_collection.handle != blank
                  assign category_label = parent_collection.title
                  assign category_url = parent_collection.url
                endif
              endif
            endif

            if category_label != blank and category_url == blank
              assign category_handle = category_label | handleize
              assign matched_collection = collections[category_handle]
              if matched_collection.handle != blank
                assign category_url = matched_collection.url
              endif
            endif
          -%}
          {%- if category_label != blank -%}
            <li class="breadcrumbs__item">
              {%- if category_url != blank -%}
                <a class="breadcrumbs__link" href="{{ category_url }}">{{ category_label }}</a>
              {%- else -%}
                <span class="breadcrumbs__link">{{ category_label }}</span>
              {%- endif -%}
            </li>
          {%- endif -%}
          <li class="breadcrumbs__item" aria-current="page">
            <span class="breadcrumbs__current">{{ product.title }}</span>
          </li>

        {%- when 'blog' -%}
          <li class="breadcrumbs__item" aria-current="page">
            <span class="breadcrumbs__current">{{ blog.title }}</span>
          </li>

        {%- when 'article' -%}
          <li class="breadcrumbs__item">
            <a class="breadcrumbs__link" href="{{ blog.url }}">{{ blog.title }}</a>
          </li>
          <li class="breadcrumbs__item" aria-current="page">
            <span class="breadcrumbs__current">{{ article.title }}</span>
          </li>

        {%- when 'page' -%}
          <li class="breadcrumbs__item" aria-current="page">
            <span class="breadcrumbs__current">{{ page.title }}</span>
          </li>

        {%- when 'search' -%}
          <li class="breadcrumbs__item" aria-current="page">
            <span class="breadcrumbs__current">{{ 'general.search.title' | t | default: 'Search' }}</span>
          </li>

        {%- else -%}
          {%- if page_title != blank and request.page_type != 'index' -%}
            <li class="breadcrumbs__item" aria-current="page">
              <span class="breadcrumbs__current">{{ page_title }}</span>
            </li>
          {%- endif -%}
      {%- endcase -%}
    </ol>
  </nav>
</div>

{% stylesheet %}
  .breadcrumbs__nav {
    width: 100%;
  }

  /* Type is in px, not rem: the theme scales the root font-size on mobile
     (CLAUDE.md gotcha #4), which would inflate a rem value well past the 14px spec. */
  .breadcrumbs__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 4px;
    font-size: var(--breadcrumbs-font-size, 14px);
    line-height: 1.2;
    color: var(--breadcrumbs-color-current, #2b2b2b);
  }

  .breadcrumbs__item {
    display: inline-flex;
    align-items: center;
    gap: 4px;
  }

  .breadcrumbs__item + .breadcrumbs__item::before {
    content: var(--breadcrumbs-separator, '/');
    color: var(--breadcrumbs-color-link, #676767);
    display: inline-block;
  }

  .breadcrumbs__link {
    color: var(--breadcrumbs-color-link, #676767);
    text-decoration: none;
    transition: color 120ms ease;
  }

  .breadcrumbs__link:hover,
  .breadcrumbs__link:focus-visible {
    color: var(--breadcrumbs-color-current, #2b2b2b);
    text-decoration: underline;
    text-underline-offset: 0.2em;
  }

  /* The trailing crumb is the current page: same weight as the rest, darker. */
  .breadcrumbs__current {
    color: var(--breadcrumbs-color-current, #2b2b2b);
    font-weight: 400;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Breadcrumbs",
  "tag": "section",
  "class": "shopify-section--breadcrumbs",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "text",
      "id": "home_label",
      "label": "Home label",
      "default": "Home"
    },
    {
      "type": "checkbox",
      "id": "show_collection_parent",
      "label": "Show \"Collection\" crumb",
      "info": "Adds a link to the all-collections page between Home and the collection name.",
      "default": true
    },
    {
      "type": "text",
      "id": "collection_parent_label",
      "label": "Collection crumb label",
      "default": "Collection",
      "visible_if": "{{ section.settings.show_collection_parent }}"
    },
    {
      "type": "select",
      "id": "product_category_source",
      "label": "Product category source",
      "info": "What to show between Home and the product name on product pages.",
      "options": [
        { "value": "auto", "label": "Auto (Category → Type → Collection)" },
        { "value": "category", "label": "Product category (admin taxonomy)" },
        { "value": "type", "label": "Product type" },
        { "value": "collection", "label": "Collection" }
      ],
      "default": "auto"
    },
    {
      "type": "select",
      "id": "separator",
      "label": "Separator",
      "options": [
        { "value": "/", "label": "Slash (/)" },
        { "value": ">", "label": "Chevron (>)" },
        { "value": "•", "label": "Dot (•)" },
        { "value": "–", "label": "Dash (–)" }
      ],
      "default": "/"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "t:settings.background_color",
      "placeholder": "t:settings.default"
    },
    {
      "type": "select",
      "id": "section_width",
      "label": "t:settings.width",
      "options": [
        { "value": "page-width", "label": "t:options.page" },
        { "value": "full-width", "label": "t:options.full" }
      ],
      "default": "page-width"
    },
    {
      "type": "header",
      "content": "t:content.padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "t:settings.top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "t:settings.bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "padding-inline-start",
      "label": "t:settings.left",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-inline-end",
      "label": "t:settings.right",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "header",
      "content": "Mobile padding"
    },
    {
      "type": "checkbox",
      "id": "use_mobile_padding",
      "label": "Use mobile padding",
      "default": false
    },
    {
      "type": "range",
      "id": "padding-block-start-mobile",
      "label": "t:settings.top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 16,
      "visible_if": "{{ section.settings.use_mobile_padding }}"
    },
    {
      "type": "range",
      "id": "padding-block-end-mobile",
      "label": "t:settings.bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 16,
      "visible_if": "{{ section.settings.use_mobile_padding }}"
    },
    {
      "type": "range",
      "id": "padding-inline-start-mobile",
      "label": "t:settings.left",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0,
      "visible_if": "{{ section.settings.use_mobile_padding }}"
    },
    {
      "type": "range",
      "id": "padding-inline-end-mobile",
      "label": "t:settings.right",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0,
      "visible_if": "{{ section.settings.use_mobile_padding }}"
    }
  ],
  "presets": [
    {
      "name": "Breadcrumbs",
      "category": "t:categories.other_sections"
    }
  ]
}
{% endschema %}
