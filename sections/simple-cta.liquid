{% liquid
  assign heading = section.settings.heading
  assign tagline = section.settings.tagline
  assign button_label = section.settings.button_label
  assign button_link = section.settings.button_link
%}

{% render 'contrast-override', background_color: section.settings.background_color, section_id: section.id %}
<div class="section-background{% if section.settings.background_color != blank %} color-custom-{{ section.id }}{% endif %}"></div>
<div
  class="{{ section.settings.custom_class }}  section section--page-width spacing-style simple-cta{% if section.settings.background_color != blank %} color-custom-{{ section.id }}{% endif %}"
  style="{% render 'spacing-style', settings: section.settings %}"
>
  <div class="simple-cta__inner">
    {%- if heading != blank -%}
      <h2 class="simple-cta__heading h4">{{ heading }}</h2>
    {%- endif -%}
    {%- if tagline != blank -%}
      <p class="simple-cta__tagline">{{ tagline }}</p>
    {%- endif -%}
    {%- if button_label != blank and button_link != blank -%}
      <a
        href="{{ button_link }}"
        class="simple-cta__button button button--primary"
      >{{ button_label }}</a>
    {%- endif -%}
  </div>
</div>

{% stylesheet %}
  .simple-cta__inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: var(--gap-md, 16px);
  }

  .simple-cta__heading {
    margin: 0;
    text-transform: uppercase;
  }

  .simple-cta__tagline {
    margin: 0;
    max-width: 36rem;
  }

  .simple-cta__button {
    margin-block-start: var(--gap-sm, 12px);
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Simple CTA",
  "tag": "section",
  "class": "simple-cta-section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Heading"
    },
    {
      "type": "text",
      "id": "tagline",
      "label": "Tagline",
      "default": "Add a short supporting line below the heading."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Shop now"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "t:settings.background_color",
      "placeholder": "t:settings.default"
    },
    {
      "type": "header",
      "content": "t:content.padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "t:settings.top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 32
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "t:settings.bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 80
    }
  ],
  "presets": [
    {
      "name": "Simple CTA",
      "category": "t:categories.other_sections"
    }
  ]
}
{% endschema %}
