{% comment %}
  The footer's top row is composed of theme blocks rendered through
  {% content_for 'blocks' %}, so it accepts the dedicated footer blocks
  (Footer email signup / Footer menu / Footer logo) AND every generic theme block —
  group, text, image, button, icon, spacer and so on — plus app blocks.

  Because Shopify does not let a section mix locally-defined blocks with @theme, the three
  footer blocks live in blocks/footer-*.liquid rather than in this schema.

  The bottom bar is its own section (sections/footer-bottom.liquid).
{% endcomment %}

{% liquid
  if section.settings.background_color != blank
    render 'contrast-override', background_color: section.settings.background_color, section_id: section.id
  endif
%}

<div
  class="section-background{% if section.settings.background_color != blank %} color-custom-{{ section.id }}{% endif %}"
></div>
<div
  class="section section--{{ section.settings.section_width }}{% if section.settings.background_color != blank %} color-custom-{{ section.id }}{% endif %}"
>
  <div
    class="footer-custom"
    style="
      --footer-fg: {{ section.settings.text_color | default: '#FEFEFE' }};
      --footer-column-gap: {{ section.settings.column_gap }}px;
      padding-block: {{ section.settings['padding-block-start'] }}px {{ section.settings['padding-block-end'] }}px;
    "
  >
    {%- comment -%}
      layout-panel-flex / --row / mobile-column are the theme's own flex container classes.
      They matter because the block width rules in base.css:4943 are scoped to
      `.layout-panel-flex--row > .group-block--width-*`: without them a stock group set to
      "fill" falls back to `width: 100%` with no flex-grow and swallows the whole row,
      collapsing the menu columns to zero. With them, every stock block sizes here exactly
      as it does in any other section.
    {%- endcomment -%}
    <div
      class="footer-custom__top layout-panel-flex layout-panel-flex--row mobile-column"
      style="
        --flex-wrap: wrap;
        --gap: {{ section.settings.column_gap }}px;
        --mobile-gap: 24px;
        --horizontal-alignment: flex-start;
        --vertical-alignment: flex-start;
        --vertical-alignment-mobile: flex-start;
      "
    >
      {% content_for 'blocks' %}
    </div>
  </div>
</div>

{% stylesheet %}
  .footer-custom {
    display: flex;
    flex-direction: column;
    width: 100%;
    color: var(--footer-fg);
    font-family: var(--font-body--family);
  }

  /* ---------- Top area ----------
     Direction and gap come from the layout-panel-flex classes on the element itself
     (column below 750 via mobile-column, row above, --gap / --mobile-gap inline). Only the
     footer-specific column proportions live here; generic theme blocks keep whatever width
     the merchant sets on them in the editor. */

  /* .layout-panel-flex sets height: 100%, which is meaningless for an auto-height footer
     and would stretch this row if the section ever gained a fixed height. */
  .footer-custom .footer-custom__top {
    height: auto;
  }

  /* base.css:2878 `.mobile-column` aligns its children to --horizontal-alignment, which
     leaves each column at its own content width. The footer stacks full-bleed on mobile,
     so the cross-axis is stretched back. */
  @media screen and (max-width: 749px) {
    .footer-custom .footer-custom__top {
      align-items: stretch;
    }
  }

  /* Mobile stacks at 24px, but the Figma leaves 40px under the newsletter before the first
     menu. :not(:last-child) so a trailing newsletter adds no dead space. */
  .footer-custom__top > .footer-block--newsletter:not(:last-child) {
    margin-block-end: 16px;
  }

  /* ---------- Tablet ----------
     Menus and logo share a row while the newsletter keeps the full width above them, which
     is what the fixed two-tier markup produced at this size. */

  @media screen and (min-width: 750px) {
    /* Row gap only — the column gap stays merchant-controlled through --gap. */
    .footer-custom .footer-custom__top {
      row-gap: 40px;
      align-items: flex-start;
    }

    .footer-custom__top > .footer-block--newsletter {
      flex: 1 0 100%;
      margin-block-end: 0;
    }

    .footer-custom__top > .footer-block--menu,
    .footer-custom__top > .footer-block--logo {
      flex: 1 1 0;
      min-width: 0;
    }
  }

  /* ---------- Desktop ---------- */

  @media screen and (min-width: 990px) {
    .footer-custom .footer-custom__top {
      flex-wrap: nowrap;
      row-gap: var(--footer-column-gap);
    }

    .footer-custom__top > .footer-block--newsletter {
      flex: 0 0 min(410px, 32%);
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:names.footer",
  "class": "section-wrapper",
  "enabled_on": {
    "groups": ["footer"]
  },
  "blocks": [
    {
      "type": "@theme"
    },
    {
      "type": "@app"
    }
  ],
  "settings": [
    {
      "type": "select",
      "id": "section_width",
      "label": "t:settings.width",
      "options": [
        {
          "value": "page-width",
          "label": "t:options.page"
        },
        {
          "value": "full-width",
          "label": "t:options.full"
        }
      ],
      "default": "page-width"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "t:settings.background_color",
      "default": "{{ settings.color_palette.color1 }}"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#FEFEFE"
    },
    {
      "type": "range",
      "id": "column_gap",
      "label": "Column gap",
      "min": 16,
      "max": 100,
      "step": 2,
      "unit": "px",
      "default": 50
    },
    {
      "type": "header",
      "content": "t:content.padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "t:settings.top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "t:settings.bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 40
    }
  ],
  "presets": [
    {
      "name": "t:names.footer",
      "category": "t:categories.footer",
      "blocks": [
        {
          "type": "footer-newsletter"
        },
        {
          "type": "footer-menu"
        },
        {
          "type": "footer-menu"
        },
        {
          "type": "footer-menu"
        },
        {
          "type": "footer-logo"
        }
      ]
    }
  ]
}
{% endschema %}
