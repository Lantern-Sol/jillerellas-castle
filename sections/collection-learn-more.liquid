{%- liquid
  assign heading = section.settings.heading
  assign body = section.settings.content

  # The Figma annotates this block "if empty, hide" — a collection with no copy should not
  # leave an empty band on the page. strip_newlines + strip catches richtext that is only
  # an empty <p></p>, which is what the editor stores when a merchant clears the field.
  assign body_text = body | strip_newlines | strip_html | strip
  assign has_content = false
  if heading != blank or body_text != blank
    assign has_content = true
  endif
-%}

{%- if has_content -%}
  {% liquid
    if section.settings.background_color != blank
      render 'contrast-override', background_color: section.settings.background_color, section_id: section.id
    endif
  %}

  <div
    class="section-background{% if section.settings.background_color != blank %} color-custom-{{ section.id }}{% endif %}"
  ></div>
  <div
    class="section section--{{ section.settings.section_width }}{% if section.settings.background_color != blank %} color-custom-{{ section.id }}{% endif %}"
  >
    <div
      class="collection-learn-more"
      style="
        --clm-heading-color: {{ section.settings.heading_color }};
        --clm-text-color: {{ section.settings.text_color }};
        --clm-rule-color: {{ section.settings.rule_color }};
        --clm-max-width: {{ section.settings.content_max_width }}px;
        --clm-lines: {{ section.settings.collapsed_lines }};
        padding-block: {{ section.settings['padding-block-start'] }}px {{ section.settings['padding-block-end'] }}px;
      "
    >
      {%- if heading != blank -%}
        <div class="collection-learn-more__heading">
          <h2 class="collection-learn-more__title">{{ heading }}</h2>
          <span class="collection-learn-more__rule" aria-hidden="true">
            <svg viewBox="0 0 68 4" fill="none" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none">
              <line x1="2" y1="2" x2="66" y2="2" stroke="currentColor" stroke-width="4" stroke-linecap="round"/>
            </svg>
          </span>
        </div>
      {%- endif -%}

      {%- if body_text != blank -%}
        <div class="collection-learn-more__body">
          <div
            class="collection-learn-more__text"
            id="CollectionLearnMoreText-{{ section.id }}"
          >
            {{ body }}
          </div>

          {%- comment -%}
            Progressive enhancement: the copy renders in full for everyone, and the script
            only clamps it (and reveals this button) once it confirms the text actually
            overflows. Without JS the reader gets all the copy rather than a truncated
            block with no way to expand it.
          {%- endcomment -%}
          <button
            type="button"
            class="collection-learn-more__toggle"
            aria-expanded="false"
            aria-controls="CollectionLearnMoreText-{{ section.id }}"
            data-label-more="{{ section.settings.more_label | escape }}"
            data-label-less="{{ section.settings.less_label | escape }}"
            hidden
          >
            {{- section.settings.more_label -}}
          </button>
        </div>
      {%- endif -%}
    </div>
  </div>
{%- endif -%}

{% stylesheet %}
  .collection-learn-more {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 24px;
    width: 100%;
    font-family: var(--font-body--family);
  }

  .collection-learn-more__heading {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 16px;
    width: 100%;
  }

  /* px rather than rem: the theme scales the root font-size on mobile
     (CLAUDE.md gotcha #4), which would push a rem value well past the 32px spec. */
  .collection-learn-more__title {
    margin: 0;
    font-family: var(--font-body--family);
    font-size: 32px;
    font-weight: 600;
    line-height: 1.2;
    letter-spacing: 0;
    text-align: center;
    color: var(--clm-heading-color, #5a3884);
  }

  .collection-learn-more__rule {
    display: block;
    width: 68px;
    height: 4px;
    color: var(--clm-rule-color, #bc9d62);
  }

  .collection-learn-more__rule svg {
    display: block;
    width: 100%;
    height: 100%;
  }

  .collection-learn-more__body {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 16px;
    width: 100%;
  }

  .collection-learn-more__text {
    position: relative;
    width: 100%;
    max-width: var(--clm-max-width, 800px);
    font-size: 16px;
    font-weight: 400;
    line-height: 1.4;
    text-align: center;
    color: var(--clm-text-color, #2b2b2b);
  }

  .collection-learn-more__text > :first-child {
    margin-block-start: 0;
  }

  .collection-learn-more__text > :last-child {
    margin-block-end: 0;
  }

  /* Only applied once the script has measured a genuine overflow. */
  .collection-learn-more__text--clamped {
    display: -webkit-box;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: var(--clm-lines, 4);
    line-clamp: var(--clm-lines, 4);
    overflow: hidden;
  }

  /* The Figma places a soft fade over the last line of the collapsed copy. */
  .collection-learn-more__text--clamped::after {
    content: '';
    position: absolute;
    inset-inline: 0;
    bottom: 0;
    height: 2.2em;
    pointer-events: none;
    background: linear-gradient(
      to bottom,
      rgb(from var(--color-background, #fefefe) r g b / 0),
      var(--color-background, #fefefe)
    );
  }

  @supports not (color: rgb(from white r g b / 1)) {
    .collection-learn-more__text--clamped::after {
      background: linear-gradient(to bottom, transparent, var(--color-background, #fefefe));
    }
  }

  .collection-learn-more__toggle {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0;
    border: 0;
    border-bottom: 1px solid var(--clm-text-color, #2b2b2b);
    border-radius: 0;
    background: none;
    color: var(--clm-text-color, #2b2b2b);
    font-family: var(--font-body--family);
    font-size: 14px;
    font-weight: 500;
    line-height: 1.2;
    cursor: pointer;
  }

  .collection-learn-more__toggle[hidden] {
    display: none;
  }

  @media screen and (max-width: 749px) {
    .collection-learn-more {
      gap: 16px;
    }

    .collection-learn-more__title {
      font-size: 28px;
    }
  }
{% endstylesheet %}

{% javascript %}
  (() => {
    const SELECTOR = '.collection-learn-more__body';

    const setup = (root) => {
      const text = root.querySelector('.collection-learn-more__text');
      const toggle = root.querySelector('.collection-learn-more__toggle');
      if (!text || !toggle || toggle.dataset.bound === 'true') return;

      const CLAMPED = 'collection-learn-more__text--clamped';

      // Measure against the unclamped element: if it already fits, there is nothing to
      // expand and the button stays hidden.
      const overflows = () => {
        text.classList.remove(CLAMPED);
        const full = text.scrollHeight;
        text.classList.add(CLAMPED);
        return text.clientHeight + 1 < full;
      };

      if (!overflows()) {
        text.classList.remove(CLAMPED);
        toggle.hidden = true;
        return;
      }

      toggle.hidden = false;
      toggle.dataset.bound = 'true';

      toggle.addEventListener('click', () => {
        const open = text.classList.toggle(CLAMPED) === false;
        toggle.setAttribute('aria-expanded', String(open));
        toggle.textContent = open ? toggle.dataset.labelLess : toggle.dataset.labelMore;
      });
    };

    const init = () => document.querySelectorAll(SELECTOR).forEach(setup);

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', init);
    } else {
      init();
    }

    // Theme editor re-renders sections without a full page load.
    document.addEventListener('shopify:section:load', init);
  })();
{% endjavascript %}

{% schema %}
{
  "name": "Collection learn more",
  "tag": "section",
  "class": "section-wrapper",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "paragraph",
      "content": "Hidden automatically when both the heading and the text are empty."
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Learn more about our collection"
    },
    {
      "type": "richtext",
      "id": "content",
      "label": "Text"
    },
    {
      "type": "range",
      "id": "collapsed_lines",
      "label": "Lines shown when collapsed",
      "min": 2,
      "max": 12,
      "step": 1,
      "default": 4
    },
    {
      "type": "text",
      "id": "more_label",
      "label": "Expand label",
      "default": "View more"
    },
    {
      "type": "text",
      "id": "less_label",
      "label": "Collapse label",
      "default": "View less"
    },
    {
      "type": "range",
      "id": "content_max_width",
      "label": "Text max width",
      "min": 400,
      "max": 1200,
      "step": 20,
      "unit": "px",
      "default": 800
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading",
      "default": "#5A3884"
    },
    {
      "type": "color",
      "id": "rule_color",
      "label": "Underline",
      "default": "#BC9D62"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text",
      "default": "#2B2B2B"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "t:settings.background_color"
    },
    {
      "type": "select",
      "id": "section_width",
      "label": "t:settings.width",
      "options": [
        { "value": "page-width", "label": "t:options.page" },
        { "value": "full-width", "label": "t:options.full" }
      ],
      "default": "page-width"
    },
    {
      "type": "header",
      "content": "t:content.padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "t:settings.top",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "t:settings.bottom",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "default": 40
    }
  ],
  "presets": [
    {
      "name": "Collection learn more",
      "category": "t:categories.other_sections"
    }
  ]
}
{% endschema %}
