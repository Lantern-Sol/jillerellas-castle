{%- comment -%}
  CTA banner — a page-width call-to-action strip with a two-tone gradient
  background, editable in the theme editor.

  Structurally this is the generic `section` (same wrapper, same nested
  group/text/button blocks via `content_for`), so the heading and button stay
  drag-and-drop editable. The one thing stock blocks can't express is a two-stop
  gradient background: the group block only offers a single solid colour. So the
  gradient (and the matching outline-button styling) is emitted here as a scoped
  <style>, driven by section settings instead of the hardcoded custom-liquid it
  replaces. The CSS targets the nested `.group-block`, which still supplies the
  padding, corner radius and layout.
{%- endcomment -%}

{{ 'hero.css' | asset_url | stylesheet_tag }}
{{ 'about-page.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign s = section.settings
  assign start = s.gradient_start | default: '#D2B989'
  assign end = s.gradient_end | default: '#BC9D62'
  assign stop = s.gradient_stop | default: 63
  assign angle = s.gradient_angle | default: 170
  assign angle_mobile = s.gradient_angle_mobile | default: 120

  # Desktop and mobile share the colours and stop; only the angle differs so the
  # gradient reads well in both the wide strip and the tall stacked card.
  capture gradient_desktop
    echo 'linear-gradient(' | append: angle | append: 'deg, ' | append: start | append: ' 0%, ' | append: end | append: ' ' | append: stop | append: '%)'
  endcapture
  capture gradient_mobile
    echo 'linear-gradient(' | append: angle_mobile | append: 'deg, ' | append: start | append: ' 0%, ' | append: end | append: ' ' | append: stop | append: '%)'
  endcapture
-%}

{%- if s.enable_gradient -%}
  <style>
    #shopify-section-{{ section.id }} .group-block {
      background: {{ gradient_desktop }};
    }

    #shopify-section-{{ section.id }} .button-secondary {
      background: transparent;
      border: 1px solid {{ s.button_text_color | default: '#FEFEFE' }};
      color: {{ s.button_text_color | default: '#FEFEFE' }};
    }

    #shopify-section-{{ section.id }} .button-secondary:hover,
    #shopify-section-{{ section.id }} .button-secondary:focus-visible {
      background: {{ s.button_text_color | default: '#FEFEFE' }};
      border-color: {{ s.button_text_color | default: '#FEFEFE' }};
      color: {{ end }};
    }

    @media (max-width: 749px) {
      #shopify-section-{{ section.id }} .group-block {
        background: {{ gradient_mobile }};
      }

      /* Group is a desktop row that stacks to a column on mobile; keep the
         stacked items centred (base.css reads the desktop cross-axis here). */
      #shopify-section-{{ section.id }} .layout-panel-flex--row {
        align-items: center;
      }
    }
  </style>
{%- endif -%}

{% capture children %}
  {% content_for 'blocks' %}
{% endcapture %}

{% render 'section',
  section: section,
  children: children,
  section_id: section.id,
  background_color: section.settings.background_color
%}

{% schema %}
{
  "name": "CTA banner",
  "class": "section-wrapper",
  "tag": "section",
  "blocks": [
    {
      "type": "@theme"
    },
    {
      "type": "@app"
    }
  ],
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "header",
      "content": "Gradient background"
    },
    {
      "type": "checkbox",
      "id": "enable_gradient",
      "label": "Use gradient background",
      "info": "When off, the banner uses the group block's own background colour.",
      "default": true
    },
    {
      "type": "color",
      "id": "gradient_start",
      "label": "Start color",
      "default": "#D2B989",
      "visible_if": "{{ section.settings.enable_gradient }}"
    },
    {
      "type": "color",
      "id": "gradient_end",
      "label": "End color",
      "default": "#BC9D62",
      "visible_if": "{{ section.settings.enable_gradient }}"
    },
    {
      "type": "range",
      "id": "gradient_stop",
      "label": "End color position",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "%",
      "default": 63,
      "visible_if": "{{ section.settings.enable_gradient }}"
    },
    {
      "type": "range",
      "id": "gradient_angle",
      "label": "Angle (desktop)",
      "min": 0,
      "max": 360,
      "step": 5,
      "unit": "deg",
      "default": 170,
      "visible_if": "{{ section.settings.enable_gradient }}"
    },
    {
      "type": "range",
      "id": "gradient_angle_mobile",
      "label": "Angle (mobile)",
      "min": 0,
      "max": 360,
      "step": 5,
      "unit": "deg",
      "default": 120,
      "visible_if": "{{ section.settings.enable_gradient }}"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Outline button color",
      "info": "Border and text of the secondary button; on hover the button fills this colour and the label turns the gradient end colour.",
      "default": "#FEFEFE",
      "visible_if": "{{ section.settings.enable_gradient }}"
    },
    {
      "type": "header",
      "content": "t:content.layout"
    },
    {
      "type": "select",
      "id": "content_direction",
      "label": "t:settings.direction",
      "options": [
        { "value": "column", "label": "t:options.vertical" },
        { "value": "row", "label": "t:options.horizontal" }
      ],
      "default": "column"
    },
    {
      "type": "checkbox",
      "id": "vertical_on_mobile",
      "label": "t:settings.vertical_on_mobile",
      "default": true,
      "visible_if": "{{ section.settings.content_direction == 'row' }}"
    },
    {
      "type": "select",
      "id": "horizontal_alignment",
      "label": "t:settings.alignment",
      "options": [
        { "value": "flex-start", "label": "t:options.left" },
        { "value": "center", "label": "t:options.center" },
        { "value": "flex-end", "label": "t:options.right" },
        { "value": "space-between", "label": "t:options.space_between" }
      ],
      "default": "flex-start",
      "visible_if": "{{ section.settings.content_direction == 'row' }}"
    },
    {
      "type": "select",
      "id": "vertical_alignment",
      "label": "t:settings.position",
      "options": [
        { "value": "flex-start", "label": "t:options.top" },
        { "value": "center", "label": "t:options.center" },
        { "value": "flex-end", "label": "t:options.bottom" }
      ],
      "default": "center",
      "visible_if": "{{ section.settings.content_direction == 'row' }}"
    },
    {
      "type": "select",
      "id": "horizontal_alignment_flex_direction_column",
      "label": "t:settings.alignment",
      "options": [
        { "value": "flex-start", "label": "t:options.left" },
        { "value": "center", "label": "t:options.center" },
        { "value": "flex-end", "label": "t:options.right" }
      ],
      "default": "center",
      "visible_if": "{{ section.settings.content_direction != 'row' }}"
    },
    {
      "type": "select",
      "id": "vertical_alignment_flex_direction_column",
      "label": "t:settings.position",
      "options": [
        { "value": "flex-start", "label": "t:options.top" },
        { "value": "center", "label": "t:options.center" },
        { "value": "flex-end", "label": "t:options.bottom" },
        { "value": "space-between", "label": "t:options.space_between" }
      ],
      "default": "center",
      "visible_if": "{{ section.settings.content_direction == 'column' }}"
    },
    {
      "type": "range",
      "id": "gap",
      "label": "t:settings.gap",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "header",
      "content": "t:content.size"
    },
    {
      "type": "select",
      "id": "section_width",
      "label": "t:settings.width",
      "options": [
        { "value": "page-width", "label": "t:options.page" },
        { "value": "narrow", "label": "t:options.narrow" },
        { "value": "full-width", "label": "t:options.full" }
      ],
      "default": "page-width"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "t:settings.background_color",
      "placeholder": "t:settings.default"
    },
    {
      "type": "header",
      "content": "t:content.padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "t:settings.top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "t:settings.bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding-inline-start",
      "label": "t:settings.left",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-inline-end",
      "label": "t:settings.right",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "text",
      "id": "custom_class",
      "label": "Custom CSS Class"
    }
  ],
  "presets": [
    {
      "name": "CTA banner",
      "category": "t:categories.banners",
      "blocks": {
        "group": {
          "type": "group",
          "name": "Banner",
          "settings": {
            "content_direction": "row",
            "vertical_on_mobile": true,
            "horizontal_alignment": "space-between",
            "vertical_alignment": "center",
            "horizontal_alignment_flex_direction_column": "center",
            "vertical_alignment_flex_direction_column": "center",
            "gap": 24,
            "use_mobile_gap": true,
            "mobile_gap": 40,
            "width": "fill",
            "background_color": "#BC9D62",
            "border_radius": 24,
            "padding-block-start": 40,
            "padding-block-end": 40,
            "padding-inline-start": 40,
            "padding-inline-end": 40,
            "use_mobile_padding": true,
            "padding-block-start-mobile": 40,
            "padding-block-end-mobile": 40,
            "padding-inline-start-mobile": 16,
            "padding-inline-end-mobile": 16
          },
          "blocks": {
            "text": {
              "type": "text",
              "name": "Heading",
              "settings": {
                "text": "<h2>Have questions? Well, we've got answers.</h2>",
                "type_preset": "custom",
                "font": "var(--font-heading--family)",
                "enable_custom_font_weight": true,
                "weight": "600",
                "font_size": "2rem",
                "line_height": "custom",
                "custom_line_height": 1.2,
                "type_preset_mobile": "custom",
                "mobile_font_size": "2rem",
                "mobile_custom_line_height": 1.2,
                "text_color": "#FEFEFE",
                "width": "fit-content",
                "alignment": "center"
              }
            },
            "button": {
              "type": "button",
              "name": "Button",
              "settings": {
                "label": "Contact us",
                "link": "/pages/contact",
                "style_class": "button-secondary",
                "button_arrow": "show",
                "width": "fit-content"
              }
            }
          },
          "block_order": ["text", "button"]
        }
      },
      "block_order": ["group"],
      "settings": {
        "enable_gradient": true,
        "content_direction": "column",
        "horizontal_alignment_flex_direction_column": "center",
        "vertical_alignment_flex_direction_column": "center",
        "gap": 0,
        "section_width": "page-width",
        "padding-block-start": 40,
        "padding-block-end": 40
      }
    }
  ]
}
{% endschema %}

