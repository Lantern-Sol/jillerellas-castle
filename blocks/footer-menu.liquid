{% comment %}
  A footer menu column (Figma node 7134-17312) — heading plus a link list. A theme block so
  sections/footer.liquid can render it through {% content_for 'blocks' %} alongside the
  generic group / text / image blocks.
{% endcomment %}

{%- liquid
  assign menu = linklists[block.settings.menu]
  assign heading = block.settings.heading | strip
  if heading == blank
    assign heading = menu.title
  endif
-%}

{%- comment -%}
  An empty menu picker would render an empty <nav> on the live site, so it is skipped there
  and shown only in the editor, where the block still has to be selectable.
{%- endcomment -%}
{%- if menu.links.size > 0 -%}
  <nav
    class="footer-block footer-block--menu"
    aria-label="{{ heading | escape }}"
    {{ block.shopify_attributes }}
  >
    {%- if heading != blank -%}
      <h2 class="footer-block__menu-heading">{{ heading }}</h2>
    {%- endif -%}
    <ul class="footer-block__links" role="list">
      {%- for link in menu.links -%}
        <li class="footer-block__links-item">
          <a href="{{ link.url }}" class="footer-block__link">{{ link.title }}</a>
        </li>
      {%- endfor -%}
    </ul>
  </nav>
{%- elsif request.design_mode -%}
  <nav
    class="footer-block footer-block--menu"
    {{ block.shopify_attributes }}
  >
    <h2 class="footer-block__menu-heading">{{ heading | default: 'Menu' }}</h2>
    <p class="footer-block__menu-empty">{{ 'content.footer_menu_empty' | t }}</p>
  </nav>
{%- endif -%}

{% stylesheet %}
  .footer-block--menu {
    display: flex;
    flex-direction: column;
    gap: 8px;
    color: var(--footer-fg, inherit);
    font-family: var(--font-body--family);
  }

  .footer-block--menu a {
    color: inherit;
    text-decoration: none;
  }

  .footer-block__menu-heading {
    margin: 0;
    font-family: var(--font-body--family);
    font-size: 18px;
    font-weight: 500;
    line-height: normal;
    letter-spacing: 0;
    color: inherit;
  }

  /* Editor-only hint shown when a menu block has no menu picked yet. */
  .footer-block__menu-empty {
    margin: 0;
    font-size: 14px;
    line-height: 1.2;
    opacity: 0.7;
  }

  .footer-block__links {
    margin: 0;
    padding: 0;
    list-style: none;
    /* Two balanced columns on mobile — matches the Figma's column-major split. */
    columns: 2;
    column-gap: 16px;
  }

  .footer-block__links-item {
    break-inside: avoid;
    margin-bottom: 8px;
  }

  .footer-block__link {
    display: inline-block;
    padding-block: 4px;
    font-size: 16px;
    font-weight: 400;
    line-height: 1.2;
  }

  .footer-block__link:hover {
    text-decoration: underline;
    text-underline-offset: 0.2em;
  }

  @media screen and (min-width: 750px) {
    .footer-block__links {
      display: flex;
      flex-direction: column;
      gap: 8px;
      columns: auto;
    }

    .footer-block__links-item {
      margin-bottom: 0;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Footer menu",
  "tag": null,
  "settings": [
    {
      "type": "link_list",
      "id": "menu",
      "label": "Menu"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "info": "Leave empty to use the menu name."
    }
  ],
  "presets": [
    {
      "name": "Footer menu",
      "category": "t:categories.layout"
    }
  ]
}
{% endschema %}
