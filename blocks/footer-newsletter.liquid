{% comment %}
  Email signup styled for the footer (Figma node 7134-17312). A theme block rather than a
  section-local block so sections/footer.liquid can render it through
  {% content_for 'blocks' %} alongside the generic group / text / image blocks.

  Colour comes from --footer-fg when the block sits in the footer, and falls back to the
  surrounding colour scheme anywhere else.
{% endcomment %}

<div
  class="footer-block footer-block--newsletter"
  {{ block.shopify_attributes }}
>
  {%- if block.settings.heading != blank -%}
    <h2 class="footer-block__newsletter-heading">{{ block.settings.heading }}</h2>
  {%- endif -%}

  {%- if block.settings.text != blank -%}
    <p class="footer-block__newsletter-text">{{ block.settings.text }}</p>
  {%- endif -%}

  {%- form 'customer', class: 'footer-block__form' -%}
    <div class="footer-block__form-row">
      <label for="FooterEmail-{{ block.id }}" class="visually-hidden">
        {{ 'blocks.email_signup.label' | t }}
      </label>
      <input
        id="FooterEmail-{{ block.id }}"
        class="footer-block__input"
        type="email"
        name="contact[email]"
        autocorrect="off"
        autocapitalize="off"
        autocomplete="email"
        placeholder="{{ block.settings.placeholder | escape }}"
        required
        {% if form.errors and form.id == blank %}
          autofocus
          aria-invalid="true"
          aria-describedby="FooterEmail-error-{{ block.id }}"
        {% elsif form.posted_successfully? and form.id == blank %}
          aria-describedby="FooterEmail-success-{{ block.id }}"
        {% endif %}
      >
      <button type="submit" class="footer-block__subscribe">
        {{- block.settings.button_label -}}
      </button>
    </div>

    {%- if form.errors and form.id == blank -%}
      <div id="FooterEmail-error-{{ block.id }}" class="footer-block__form-message" tabindex="-1">
        {{- form.errors.translated_fields.email | capitalize }} {{ form.errors.messages.email -}}
      </div>
    {%- endif -%}

    {%- if form.posted_successfully? and form.id == blank -%}
      <div id="FooterEmail-success-{{ block.id }}" class="footer-block__form-message" tabindex="-1">
        {{- 'blocks.email_signup.success' | t -}}
      </div>
    {%- endif -%}
  {%- endform -%}
</div>

{% stylesheet %}
  .footer-block--newsletter {
    display: flex;
    flex-direction: column;
    gap: 16px;
    color: var(--footer-fg, inherit);
    font-family: var(--font-body--family);
  }

  .footer-block__newsletter-heading {
    margin: 0;
    font-family: var(--font-body--family);
    font-size: 32px;
    font-weight: 600;
    line-height: 1.2;
    letter-spacing: 0;
    color: inherit;
  }

  .footer-block__newsletter-text {
    margin: 0;
    font-size: 16px;
    font-weight: 400;
    line-height: 1.2;
  }

  .footer-block__form {
    display: flex;
    flex-direction: column;
    gap: 8px;
    width: 100%;
  }

  .footer-block__form-row {
    display: flex;
    flex-direction: column;
    gap: 8px;
    width: 100%;
  }

  /* Doubled class to out-specify base.css `input:not([type='checkbox'], [type='radio'])`
     (0,1,1), which otherwise forces --color-input-background/-border onto this field. */
  .footer-block__input.footer-block__input {
    box-sizing: border-box;
    width: 100%;
    height: 48px;
    padding-inline: 16px;
    border: 1px solid #e0d2b7;
    border-radius: 32px;
    background-color: #fcfaf9;
    color: #2b2b2b;
    font-family: var(--font-body--family);
    font-size: 14px;
    font-weight: 400;
    line-height: 1.2;
    box-shadow: none;
  }

  .footer-block__input.footer-block__input::placeholder {
    color: #676767;
    opacity: 1;
  }

  /*.footer-block__input:focus-visible {
    outline: 2px solid var(--footer-fg, currentcolor);
    outline-offset: 2px;
  }*/

  /* Deliberately not .button: brand-components.css injects a chevron into text-only
     buttons carrying that class, and the Figma button has none. */
  .footer-block__subscribe {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    width: 100%;
    height: 48px;
    padding: 12px 24px;
    border: 0;
    border-radius: 50px;
    background-color: #bc9d62;
    color: var(--footer-fg, #fefefe);
    font-family: var(--font-body--family);
    font-size: 16px;
    font-weight: 500;
    line-height: 1.2;
    white-space: nowrap;
    cursor: pointer;
    transition: background-color var(--animation-speed, 0.2s) var(--animation-easing, ease);
  }

  .footer-block__subscribe:hover {
    background-color: #2b2b2b;
  }

  .footer-block__form-message {
    margin: 0;
    font-size: 14px;
    line-height: 1.2;
  }

  @media screen and (min-width: 990px) {
    .footer-block__form-row {
      flex-direction: row;
      align-items: center;
    }

    .footer-block__input {
      flex: 1 1 0;
      min-width: 0;
    }

    .footer-block__subscribe {
      width: auto;
      flex: 0 0 auto;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Footer email signup",
  "tag": null,
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Join the castle list"
    },
    {
      "type": "text",
      "id": "text",
      "label": "Description",
      "default": "First looks, little restocks, and a treat now and then."
    },
    {
      "type": "text",
      "id": "placeholder",
      "label": "Input placeholder",
      "default": "Your email address"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Subscribe"
    }
  ],
  "presets": [
    {
      "name": "Footer email signup",
      "category": "t:categories.forms"
    }
  ]
}
{% endschema %}
