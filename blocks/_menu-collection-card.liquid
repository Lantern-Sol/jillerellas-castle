{%- doc -%}
  Menu collection card — a gradient/color promo card rendered inside the
  header's "Collections" card submenu (desktop mega panel + mobile drawer
  2-column grid). Merchants add these as nested blocks of the header Menu
  block; title, subtitle, button label, link, background (solid or
  gradient) and text color are all editor settings.
{%- enddoc -%}

<a
  {% if block.settings.link != blank %}
    href="{{ block.settings.link }}"
  {% endif %}
  class="menu-collection-card"
  style="
    --card-background: {{ block.settings.card_background | default: 'var(--color-primary-button-background)' }};
    --card-text: {{ block.settings.text_color | default: '#FEFEFE' }};
  "
  {{ block.shopify_attributes }}
>
  <span class="menu-collection-card__content">
    <span class="menu-collection-card__text">
      {%- if block.settings.title != blank -%}
        <span class="menu-collection-card__title">{{ block.settings.title }}</span>
      {%- endif -%}
      {%- if block.settings.subtitle != blank -%}
        <span class="menu-collection-card__subtitle">{{ block.settings.subtitle }}</span>
      {%- endif -%}
    </span>
    {%- if block.settings.button_label != blank -%}
      <span class="menu-collection-card__cta">
        <span>{{ block.settings.button_label }}</span>
        <span class="svg-wrapper menu-collection-card__cta-icon" aria-hidden="true">
          {{- 'icon-angle-right.svg' | inline_asset_content -}}
        </span>
      </span>
    {%- endif -%}
  </span>
</a>

{% stylesheet %}
  .menu-collection-card {
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding-top: 60px;
    border-radius: 16px;
    background: var(--card-background);
    color: var(--card-text);
    text-decoration: none;
    overflow: hidden;
    /* The desktop submenu lives inside .menu-list__list-item, which sets
       white-space: nowrap for nav pills — reset it so card text wraps
       instead of clipping at narrow widths. */
    white-space: normal;
    overflow-wrap: break-word;
  }

  .menu-collection-card:hover {
    color: var(--card-text);
    text-decoration: none;
  }

  @media screen and (min-width: 750px) {
    .menu-collection-card {
      padding-top: 0;
      min-height: 168px;
    }
  }

  .menu-collection-card__content {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 16px;
    padding: 0 16px 16px;
  }

  .menu-collection-card__text {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 8px;
  }

  .menu-collection-card__title {
    font-family: var(--font-subheading--family);
    font-weight: 600;
    font-size: 20px;
    line-height: 1.2;
  }

  .menu-collection-card__subtitle {
    font-family: var(--font-body--family);
    font-weight: 400;
    font-size: 14px;
    line-height: 1.2;
  }

  .menu-collection-card__cta {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-subheading--family);
    font-weight: 500;
    font-size: 14px;
    line-height: 1.2;
  }

  .menu-collection-card__cta-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 16px;
    height: 16px;
    flex-shrink: 0;
  }

  .menu-collection-card__cta-icon svg {
    width: auto;
    height: 11px;
  }

  @media screen and (min-width: 750px) {
    .menu-collection-card__title {
      font-size: 24px;
    }

    .menu-collection-card__subtitle {
      font-size: 16px;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Collection card",
  "tag": null,
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Women"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Sterling, sparkle & everyday comfort."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Shop now"
    },
    {
      "type": "url",
      "id": "link",
      "label": "Link"
    },
    {
      "type": "color_background",
      "id": "card_background",
      "label": "Card background",
      "default": "linear-gradient(117deg, #EC4B9B 0%, #A90255 100%)"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#FEFEFE"
    }
  ]
}
{% endschema %}
