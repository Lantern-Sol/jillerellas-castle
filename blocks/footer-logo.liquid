{% comment %}
  Footer logo (Figma node 7134-17312). A theme block so sections/footer.liquid can render it
  through {% content_for 'blocks' %} alongside the generic group / text / image blocks.

  The image picker is optional: with nothing chosen it falls back to the inverse logo from
  theme settings, then the main logo, then the shop name as text.
{% endcomment %}

{%- liquid
  assign block_logo = block.settings.image
  if block_logo == blank
    assign block_logo = settings.logo_inverse
  endif
  if block_logo == blank
    assign block_logo = settings.logo
  endif

  assign logo_link = block.settings.link | default: routes.root_url

  capture sizes_attr
    echo '(min-width: 750px) '
    echo block.settings.logo_width
    echo 'px, 192px'
  endcapture
-%}

<div
  class="footer-block footer-block--logo"
  style="--footer-logo-width: {{ block.settings.logo_width }}px;"
  {{ block.shopify_attributes }}
>
  <a href="{{ logo_link }}" class="footer-block__logo">
    {%- if block_logo != blank -%}
      {{
        block_logo
        | image_url: width: 800
        | image_tag:
          width: block_logo.width,
          height: block_logo.height,
          widths: '200, 400, 600, 800',
          sizes: sizes_attr,
          alt: shop.name,
          loading: 'lazy',
          class: 'footer-block__logo-image'
      }}
    {%- else -%}
      <span class="footer-block__logo-text">{{ shop.name }}</span>
    {%- endif -%}
  </a>
</div>

{% stylesheet %}
  .footer-block--logo {
    display: flex;
    flex-direction: column;
    align-items: center;
    color: var(--footer-fg, inherit);
    font-family: var(--font-body--family);
  }

  .footer-block--logo a {
    color: inherit;
    text-decoration: none;
  }

  .footer-block__logo {
    display: flex;
    width: 192px;
    max-width: 100%;
  }

  .footer-block__logo-image {
    width: 100%;
    height: auto;
    object-fit: contain;
  }

  .footer-block__logo-text {
    font-size: 24px;
    font-weight: 500;
    line-height: 1.2;
  }

  @media screen and (min-width: 750px) {
    .footer-block--logo {
      align-items: flex-end;
    }

    .footer-block__logo {
      width: var(--footer-logo-width, 192px);
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Footer logo",
  "tag": null,
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image",
      "info": "Leave empty to use the inverse logo from theme settings, then the main logo."
    },
    {
      "type": "range",
      "id": "logo_width",
      "label": "Width",
      "min": 80,
      "max": 320,
      "step": 4,
      "unit": "px",
      "default": 188
    },
    {
      "type": "url",
      "id": "link",
      "label": "Link",
      "info": "Defaults to the home page."
    }
  ],
  "presets": [
    {
      "name": "Footer logo",
      "category": "t:categories.layout"
    }
  ]
}
{% endschema %}
