{%- doc -%}
  One reassurance line in the product highlights grid — a filled, rounded icon tile
  followed by a bold headline and a lighter supporting line.

  Lives inside `product-highlights`, which owns the grid; this block only draws a row.
{%- enddoc -%}

{%- liquid
  assign block_settings = block.settings
  assign icon_size = block_settings.tile_size | times: 0.6 | round
-%}

<div
  class="product-highlight"
  style="
    --product-highlight-tile-size: {{ block_settings.tile_size }}px;
    --product-highlight-tile-radius: {{ block_settings.tile_radius }}px;
    --product-highlight-tile-background: {{ block_settings.tile_background }};
    --product-highlight-icon-color: {{ block_settings.icon_color }};
    --product-highlight-gap: {{ block_settings.gap }}px;
    {% if block_settings.title_color != blank %}--product-highlight-title-color: {{ block_settings.title_color }};{% endif %}
    {% if block_settings.subtitle_color != blank %}--product-highlight-subtitle-color: {{ block_settings.subtitle_color }};{% endif %}
  "
  {{ block.shopify_attributes }}
>
  {%- if block_settings.image_upload != blank -%}
    <span class="product-highlight__tile">
      {{
        block_settings.image_upload
        | image_url: width: 120
        | image_tag: loading: 'lazy', alt: '', class: 'product-highlight__image', widths: '40, 80, 120'
      }}
    </span>
  {%- elsif block_settings.icon != 'none' -%}
    <span class="product-highlight__tile">
      <svg
        class="product-highlight__icon"
        aria-hidden="true"
        focusable="false"
        xmlns="http://www.w3.org/2000/svg"
        width="{{ icon_size }}"
        height="{{ icon_size }}"
        viewBox="0 0 20 20"
      >
        {%- render 'icon', icon: block_settings.icon -%}
      </svg>
    </span>
  {%- endif -%}

  <span class="product-highlight__text">
    {%- if block_settings.title != blank -%}
      <span class="product-highlight__title">{{ block_settings.title }}</span>
    {%- endif -%}
    {%- if block_settings.subtitle != blank -%}
      <span class="product-highlight__subtitle">{{ block_settings.subtitle }}</span>
    {%- endif -%}
  </span>
</div>

{% stylesheet %}
  .product-highlight {
    display: flex;
    align-items: center;
    gap: var(--product-highlight-gap, 12px);
    min-width: 0;
  }

  .product-highlight__tile {
    flex: 0 0 auto;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    inline-size: var(--product-highlight-tile-size, 32px);
    block-size: var(--product-highlight-tile-size, 32px);
    border-radius: var(--product-highlight-tile-radius, 6px);
    background: var(--product-highlight-tile-background, #5a3884);
    color: var(--product-highlight-icon-color, #fefefe);
    overflow: hidden;
  }

  /* `fill: currentColor` is what makes the glyph take the tile's colour. Most paths in
     snippets/icon.liquid carry no `fill` of their own and would otherwise render black —
     the stock icon block gets this from `.icon-default` in base.css. */
  .product-highlight__icon {
    display: block;
    fill: currentColor;
  }

  .product-highlight__image {
    inline-size: 100%;
    block-size: 100%;
    object-fit: cover;
  }

  .product-highlight__text {
    display: flex;
    flex-direction: column;
    gap: 4px;
    min-width: 0;
  }

  /* px, not rem: the theme scales the root font-size on mobile (CLAUDE.md gotcha #4)
     and the Figma keeps these at 14/12 on both breakpoints. */
  .product-highlight__title {
    font-family: var(--font-body--family);
    font-size: 14px;
    font-weight: 500;
    line-height: 1.2;
    letter-spacing: normal;
    color: var(--product-highlight-title-color, #2b2b2b);
  }

  .product-highlight__subtitle {
    font-family: var(--font-body--family);
    font-size: 12px;
    font-weight: 400;
    line-height: 1.2;
    letter-spacing: normal;
    color: var(--product-highlight-subtitle-color, #676767);
  }
{% endstylesheet %}

